# App — production: https://multi-flame.vercel.app
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://multi-flame.vercel.app
APP_NAME=MultiPoster TN

# MongoDB (MongoDB Atlas on Vercel)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/multiposter-tn

# JWT — generate new secrets for production (openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (OAuth tokens) - exactly 32 characters
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Redis / BullMQ (Upstash on Vercel: https://upstash.com)
REDIS_URL=redis://default:password@host.upstash.io:6379

# Storage (use S3 on Vercel — local storage is ephemeral)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Vercel Blob — required for video uploads on Vercel (auto-set when Blob store is linked)
BLOB_READ_WRITE_TOKEN=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@multiposter.tn

# OAuth - Meta (Instagram/Facebook)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://multi-flame.vercel.app/api/oauth/instagram/callback

# OAuth - TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://multi-flame.vercel.app/api/oauth/tiktok/callback

# OAuth - YouTube (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://multi-flame.vercel.app/api/oauth/youtube/callback

# AI - Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Admin
ADMIN_EMAIL=admin@multiposter.tn
