# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=MultiPoster TN

# MongoDB
MONGODB_URI=mongodb://localhost:27017/multiposter-tn

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (OAuth tokens) - 32 byte hex key
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@multiposter.tn

# OAuth - Meta (Instagram/Facebook)
META_APP_ID=
META_APP_SECRET=
# Optional — auto-derived from NEXT_PUBLIC_APP_URL if omitted
# META_REDIRECT_URI=https://your-app.vercel.app/api/oauth/instagram/callback

# OAuth - TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Optional — auto-derived from NEXT_PUBLIC_APP_URL if omitted
# TIKTOK_REDIRECT_URI=https://your-app.vercel.app/api/oauth/tiktok/callback

# OAuth - YouTube (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/oauth/youtube/callback

# AI - Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Admin
ADMIN_EMAIL=admin@multiposter.tn
